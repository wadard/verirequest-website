# ========= MAIN ENGINE =========

def test_send():
    print("=== TEST SEND MODE (Graph API) ===")
    to = ["jawoodward@hotmail.co.uk"]
    subject = "Data Subject Access Request Support"
    body = build_body(1)

    ok, err = send_email(to, body, subject)
    if ok:
        print("[TEST SENT] Email delivered successfully.")
    else:
        print("[TEST FAILED]", err)

def main():
    if "--test" in sys.argv:
        test_send()
        return

    print("=== DAILY OUTBOUND ENGINE (VeriRequest, Graph API) ===")

    today = now_local().date()
    if today.weekday() >= 5:
        print("[INFO] Weekend detected. No emails will be sent.")
        return

    unsubscribed = load_unsubscribed()
    sent_already = load_log()
    candidates = load_candidates(sent_already, unsubscribed)

    if not candidates:
        print("[INFO] No unsent schools available (or all filtered by unsubscribe).")
        return

    print(f"[INFO] Preparing to send {len(candidates)} emails today.")

    send_times = schedule_times(len(candidates))
    now = now_local()

    if now > send_times[-1]:
        print("[FATAL] Current time is past the last scheduled window. Run earlier.")
        return

    daily_summary = []

    for (school_site, raw_email), send_at in zip(candidates, send_times):
        now = now_local()
        if now < send_at:
            wait_sec = (send_at - now).total_seconds()
            print(f"[INFO] Waiting {int(wait_sec)}s until {send_at.time()} for {raw_email} ({school_site})")
            time.sleep(wait_sec)

        if any_recipient_unsubscribed(raw_email, unsubscribed):
            print(f"[SKIP] {raw_email} ({school_site}) is unsubscribed at send time.")
            append_log(school_site, raw_email, "UNSUBSCRIBED_SKIP")
            daily_summary.append((raw_email, school_site, "UNSUBSCRIBED_SKIP"))
            continue

        recipients = parse_recipients(raw_email)
        if not recipients:
            print(f"[FAIL] No valid recipients for {school_site}")
            append_log(school_site, raw_email, "FAILED")
            daily_summary.append((raw_email, school_site, "FAILED"))
            continue

        variant = random.randint(1, 4)
        subject = "Data Subject Access Request Support"
        body = build_body(variant)

        ok, err = send_email(recipients, body, subject)
        if ok:
            print(f"[SENT] {raw_email} ({school_site}) variant={variant} at {now_local().time()}")
            append_log(school_site, f"{raw_email} | variant={variant}", "SENT")
            daily_summary.append((raw_email, school_site, f"SENT (variant {variant})"))
        else:
            print(f"[FAIL] {raw_email} ({school_site}) → {err}")
            append_log(school_site, raw_email, "FAILED")
            daily_summary.append((raw_email, school_site, "FAILED"))

    print("\n=== DAILY SUMMARY ===")
    for email, site, status in daily_summary:
        print(f"{email} ({site}) → {status}")

if __name__ == "__main__":
    main()

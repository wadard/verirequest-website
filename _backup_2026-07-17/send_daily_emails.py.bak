#!/usr/bin/env python3
import csv
import datetime as dt
import random
import sys
import time
from pathlib import Path
import requests
import json

# ========= CONFIG =========

SCRIPT_DIR = Path("/Users/jakewoodward/Desktop/verirequest-website/scraper")

SCHOOLS_CSV = SCRIPT_DIR.parent / "data" / "school_emails_final_clean.csv"
LOG_CSV = SCRIPT_DIR.parent / "data" / "email_send_log.csv"
UNSUBSCRIBE_CSV = SCRIPT_DIR.parent / "data" / "unsubscribe_list.csv"

EMAILS_PER_DAY = 7

# *** YOUR REAL CREDENTIALS — DO NOT OVERWRITE THESE ***
TENANT_ID = "REDACTED"
CLIENT_ID = "REDACTED"
CLIENT_SECRET = "REDACTED"
SENDER = "jake.woodward@comms.verirequest.co.uk"

# *** DO NOT RE‑ADD PLACEHOLDERS BELOW ***

# New unified morning window
SEND_START = dt.time(8, 0)
SEND_END = dt.time(9, 0)

# ========= HELPERS =========

def now_local():
    return dt.datetime.now()

def parse_recipients(raw):
    emails = [e.strip() for e in raw.split(";") if e.strip()]
    valid = [e for e in emails if "@" in e and "." in e]
    return valid

def load_unsubscribed():
    unsub = set()
    if not UNSUBSCRIBE_CSV.exists():
        return unsub
    with UNSUBSCRIBE_CSV.open() as f:
        for line in f:
            email = line.strip().lower()
            if email:
                unsub.add(email)
    return unsub

def any_recipient_unsubscribed(raw_email, unsub_set):
    for addr in parse_recipients(raw_email):
        if addr.lower() in unsub_set:
            return True
    return False

# ========= GRAPH API WITH TOKEN DEBUGGING =========

def graph_send_email(to_addrs, subject, body):
    token_url = f"https://login.microsoftonline.com/{TENANT_ID}/oauth2/v2.0/token"
    token_data = {
        "client_id": CLIENT_ID,
        "scope": "https://graph.microsoft.com/.default",
        "client_secret": CLIENT_SECRET,
        "grant_type": "client_credentials",
    }

    token_r = requests.post(token_url, data=token_data)

    # === DEBUG OUTPUT ===
    print("\n=== TOKEN DEBUG ===")
    print("Status:", token_r.status_code)
    print("Raw body (first 500 chars):")
    print(token_r.text[:500])
    print("===================\n")

    if token_r.status_code != 200:
        return False, f"Token error: {token_r.status_code} {token_r.text}"

    try:
        token = token_r.json().get("access_token")
    except Exception as e:
        return False, f"Token JSON parse error: {e} | Body: {token_r.text[:500]}"

    if not token:
        return False, f"Failed to obtain access token. Raw body: {token_r.text[:500]}"

    email = {
        "message": {
            "subject": subject,
            "body": {"contentType": "Text", "content": body},
            "toRecipients": [{"emailAddress": {"address": addr}} for addr in to_addrs],
            "from": {"emailAddress": {"address": SENDER}},
        },
        "saveToSentItems": True,
    }

    send_url = f"https://graph.microsoft.com/v1.0/users/{SENDER}/sendMail"
    headers = {"Authorization": f"Bearer {token}", "Content-Type": "application/json"}

    r = requests.post(send_url, headers=headers, data=json.dumps(email))

    if r.status_code == 202:
        return True, ""
    else:
        return False, f"Send error: {r.status_code} {r.text}"

def send_email(to_addrs, body, subject):
    return graph_send_email(to_addrs, subject, body)

def load_log():
    sent = set()
    if LOG_CSV.exists():
        with LOG_CSV.open(newline="", encoding="utf-8") as f:
            reader = csv.DictReader(f)
            for row in reader:
                if row.get("Status") == "SENT":
                    sent.add(row["SchoolWebsite"])
    return sent

def append_log(school_website, email, status):
    LOG_CSV.parent.mkdir(parents=True, exist_ok=True)
    file_exists = LOG_CSV.exists()
    with LOG_CSV.open("a", newline="", encoding="utf-8") as f:
        fieldnames = ["SchoolWebsite", "FinalEmail", "SentTimestamp", "Status"]
        writer = csv.DictWriter(f, fieldnames=fieldnames)
        if not file_exists:
            writer.writeheader()
        writer.writerow({
            "SchoolWebsite": school_website,
            "FinalEmail": email,
            "SentTimestamp": now_local().isoformat(),
            "Status": status,
        })

def load_candidates(sent_already, unsubscribed):
    candidates = []
    with SCHOOLS_CSV.open(newline="", encoding="utf-8") as f:
        reader = csv.DictReader(f)
        for row in reader:
            site = row["SchoolWebsite"]
            email = row["FinalEmail"]
            if not email:
                continue
            if any_recipient_unsubscribed(email, unsubscribed):
                continue
            if site not in sent_already:
                candidates.append((site, email))
    return candidates[:EMAILS_PER_DAY]

# ========= NEW UNIFIED SCHEDULER (08:00–09:00 ONLY) =========

def schedule_times(n):
    today = now_local().date()

    def rand_time(start, end):
        start_dt = dt.datetime.combine(today, start)
        end_dt = dt.datetime.combine(today, end)
        delta = (end_dt - start_dt).seconds
        offset = random.randint(0, delta)
        return start_dt + dt.timedelta(seconds=offset)

    slots = [rand_time(SEND_START, SEND_END) for _ in range(n)]
    slots.sort()
    return slots

# ========= EMAIL VARIANTS (unchanged) =========

